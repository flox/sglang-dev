#!/usr/bin/env bash
# sglang-resolve-model — Resolve bundled HF models from Flox env closure.
#
# Required:
#   SGLANG_MODEL   — HF model ID (e.g., microsoft/Phi-4-mini-instruct-FP8-TORCHAO) or local path
#   FLOX_ENV       — Flox environment path (for share/models/hub/ lookup)
#
# Optional:
#   FLOX_ENV_CACHE          — cache dir for env file and tokenizer compat shadow
#   SGLANG_MODEL_ENV_FILE   — override env file path (default: $FLOX_ENV_CACHE/sglang-model.env)
#
# Output:
#   Writes an env file exporting:
#     SGLANG_MODEL, SGLANG_BUNDLED_FROM, HF_HUB_OFFLINE (when bundled)
#
# If SGLANG_MODEL is already a local directory with config.json, it is used as-is.
# If it looks like an HF model ID (contains "/"), the script checks
# $FLOX_ENV/share/models/hub/models--<slug>/ for a bundled snapshot.
# If no bundled model is found, SGLANG_MODEL is left unchanged (SGLang downloads at runtime).

set -euo pipefail

_die() { echo "ERROR: $*" >&2; exit 1; }

# ── Inputs ──────────────────────────────────────────────────────────

: "${SGLANG_MODEL:?Set SGLANG_MODEL (HF model ID or local path)}"
: "${FLOX_ENV:?Set FLOX_ENV}"

FLOX_ENV_CACHE="${FLOX_ENV_CACHE:-$HOME/.cache/flox}"
SGLANG_MODEL_ENV_FILE="${SGLANG_MODEL_ENV_FILE:-$FLOX_ENV_CACHE/sglang-model.env}"

mkdir -p "$(dirname "$SGLANG_MODEL_ENV_FILE")"

# ── Helpers ─────────────────────────────────────────────────────────

_env_quote() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\t'/\\t}
  s=${s//$'\r'/\\r}
  printf '"%s"' "$s"
}

_write_env() {
  local tmp
  tmp="$(mktemp "${SGLANG_MODEL_ENV_FILE}.tmp.XXXXXX")"
  {
    echo "# generated by sglang-resolve-model"
    printf 'export SGLANG_MODEL=%s\n' "$(_env_quote "$SGLANG_MODEL")"
    if [[ -n "${SGLANG_BUNDLED_FROM:-}" ]]; then
      printf 'export SGLANG_BUNDLED_FROM=%s\n' "$(_env_quote "$SGLANG_BUNDLED_FROM")"
      printf 'export HF_HUB_OFFLINE=1\n'
    fi
  } >"$tmp"
  mv -f "$tmp" "$SGLANG_MODEL_ENV_FILE"
}

# ── Case 1: Already a local directory ───────────────────────────────

if [[ -d "$SGLANG_MODEL" && -f "$SGLANG_MODEL/config.json" ]]; then
  echo "[model] Using local model directory: $SGLANG_MODEL" >&2
  _write_env
  echo "[model] Env file: $SGLANG_MODEL_ENV_FILE" >&2
  exit 0
fi

# ── Case 2: HF model ID (contains "/") ─────────────────────────────

SGLANG_BUNDLED_FROM=""

case "$SGLANG_MODEL" in
  */*)
    _hf_slug="${SGLANG_MODEL//\//-\-}"
    _hub_dir="$FLOX_ENV/share/models/hub/models--${_hf_slug}"
    _resolved_dir=""

    if [[ -d "$_hub_dir/snapshots" ]]; then
      # Try refs/main first
      if [[ -f "$_hub_dir/refs/main" ]]; then
        _snap_hash="$(cat "$_hub_dir/refs/main")"
        if [[ -d "$_hub_dir/snapshots/$_snap_hash" ]]; then
          _resolved_dir="$_hub_dir/snapshots/$_snap_hash"
        fi
      fi
      # Fallback: first snapshot directory
      if [[ -z "$_resolved_dir" ]]; then
        for _d in "$_hub_dir/snapshots"/*/; do
          if [[ -d "$_d" ]]; then
            _resolved_dir="${_d%/}"
            break
          fi
        done
      fi
    fi

    # Validate
    if [[ -n "$_resolved_dir" && -f "$_resolved_dir/config.json" ]]; then
      SGLANG_BUNDLED_FROM="$SGLANG_MODEL"

      # ── TokenizersBackend shim ──
      # Models built with transformers >=4.58 may have tokenizer_class=TokenizersBackend
      # which SGLang's bundled transformers 4.57.6 doesn't recognize.
      # Create a shadow dir with symlinks + patched tokenizer_config.json.
      # Remove once SGLang ships transformers >=4.58.
      _tc_file="$_resolved_dir/tokenizer_config.json"
      if [[ -f "$_tc_file" ]] && grep -q '"TokenizersBackend"' "$_tc_file"; then
        _shadow="$FLOX_ENV_CACHE/sglang-compat/$(basename "$_resolved_dir")"
        if [[ ! -f "$_shadow/tokenizer_config.json" ]] || ! grep -q '"PreTrainedTokenizerFast"' "$_shadow/tokenizer_config.json"; then
          rm -rf "$_shadow"
          mkdir -p "$_shadow"
          ln -sf "$_resolved_dir"/* "$_shadow/"
          rm -f "$_shadow/tokenizer_config.json"
          sed 's/"TokenizersBackend"/"PreTrainedTokenizerFast"/g' "$_tc_file" > "$_shadow/tokenizer_config.json"
        fi
        _resolved_dir="$_shadow"
        echo "  tokenizer compat: TokenizersBackend -> PreTrainedTokenizerFast (shadow)" >&2
      fi

      SGLANG_MODEL="$_resolved_dir"
      export HF_HUB_OFFLINE=1
      echo "[model] Bundled: $SGLANG_BUNDLED_FROM -> $SGLANG_MODEL" >&2
    else
      echo "[model] No bundled model found for $SGLANG_MODEL; SGLang will download at runtime" >&2
    fi
    ;;
  *)
    echo "[model] SGLANG_MODEL=$SGLANG_MODEL (not an HF ID, not a local dir — passing through)" >&2
    ;;
esac

# ── Write env file ──────────────────────────────────────────────────

_write_env
echo "[model] Env file: $SGLANG_MODEL_ENV_FILE" >&2
